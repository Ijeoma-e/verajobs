# Backend Configuration

# Server Port (default: 3000)
PORT=3000

# AI Provider Selection: 'gemini', 'zai', or 'openrouter'
AI_PROVIDER=gemini

# --- Google Gemini ---
# Get key from: https://ai.google.dev
GEMINI_API_KEY=

# --- Z.AI (GLM-4-Flash) ---
# Get key from: https://z.ai
ZAI_API_KEY=

# --- OpenRouter (Multiple Models) ---
# Get key from: https://openrouter.ai
OPENROUTER_API_KEY=
# Optional: specify which model to use (default: google/gemini-2.0-flash-lite)
OPENROUTER_MODEL=google/gemini-2.0-flash-lite
